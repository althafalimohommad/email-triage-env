# Email Triage Environment - API Configuration
# ============================================
# Copy this file to .env and fill in your actual API credentials

# Required: LiteLLM Proxy URL (from hackathon validator)
API_BASE_URL=https://your-litellm-proxy-url/v1

# Required: LiteLLM Proxy API Key (from hackathon validator)
API_KEY=your-api-key-here

# Optional: Custom model name (defaults to meta-llama/Llama-3.3-70B-Instruct)
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Optional: Hugging Face API token (if needed)
HF_TOKEN=your-hf-token-here

# Optional: Environment server URL (defaults to http://localhost:8000)
ENV_URL=http://localhost:8000
